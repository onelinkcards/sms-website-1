{
  "version": 2,
  "functions": {
    "api/router.php": {
      "runtime": "vercel-php@0.9.0",
      "includeFiles": "{*.php,api/**/*.php,partials/**/*.php,storage/**}",
      "excludeFiles": "{.git/**,.vercel/**,assets/**,photo/**,reference/**}"
    }
  },
  "routes": [
    { "src": "/assets/(.*)", "dest": "https://cdn.jsdelivr.net/gh/onelinkcards/sms-websites@main/assets/$1" },
    { "src": "/", "dest": "/api/router.php" },
    { "src": "/[^/]+\\.php", "dest": "/api/router.php" },
    { "handle": "filesystem" }
  ]
}
