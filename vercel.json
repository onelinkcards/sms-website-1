{
  "version": 2,
  "functions": {
    "api/router.php": {
      "runtime": "vercel-php@0.9.0",
      "excludeFiles": [
        "assets/**",
        "photo/**",
        "reference/**",
        "**/*.png",
        "**/*.jpg",
        "**/*.jpeg",
        "**/*.webp",
        "**/*.gif",
        "**/*.svg",
        "**/*.mp4",
        "**/*.pdf",
        "**/*.woff",
        "**/*.woff2",
        "**/*.ttf",
        "**/*.eot",
        "**/*.scss",
        "**/*.map"
      ]
    }
  },
  "routes": [
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/", "dest": "/api/router.php" },
    { "src": "/[^/]+\\.php", "dest": "/api/router.php" },
    { "handle": "filesystem" }
  ]
}
